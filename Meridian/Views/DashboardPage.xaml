<Page x:Class="Meridian.Views.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:utu="using:Uno.Toolkit.UI"
      xmlns:lvc="using:LiveChartsCore.SkiaSharpView.WinUI"
      xmlns:controls="using:Meridian.Controls"
      xmlns:views="using:Meridian.Views"
      xmlns:converters="using:Meridian.Presentation"
      Background="{StaticResource MeridianBackgroundBrush}">

    <Page.Resources>
        <converters:TagToBrushConverter x:Key="TagToBrush" />
        <converters:GainLossBrushConverter x:Key="GainLossBrush" />
        <converters:DecimalFormatConverter x:Key="DecimalFormat" />
        <converters:IsPositiveConverter x:Key="IsPositive" />
    </Page.Resources>

    <Grid>
    <ScrollViewer>
        <Grid MaxWidth="1400" HorizontalAlignment="Center" Padding="32,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- ═══════════ ROW 0: HEADER ═══════════ -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal"
                            Spacing="12" VerticalAlignment="Center">
                    <TextBlock Text="Meridian"
                               FontFamily="{StaticResource InstrumentSerifItalicFont}"
                               FontSize="26"
                               Foreground="{StaticResource MeridianTextPrimaryBrush}" />
                    <TextBlock Text="CAPITAL TERMINAL"
                               FontFamily="{StaticResource OutfitFont}"
                               FontSize="10" FontWeight="Medium"
                               Foreground="{StaticResource MeridianTextSubtleBrush}"
                               CharacterSpacing="120"
                               VerticalAlignment="Center" />
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal"
                            Spacing="20" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock Text="⠋" FontSize="14"
                                   Foreground="{StaticResource MeridianGainBrush}"
                                   x:Name="BrailleSpinner"
                                   AutomationProperties.AccessibilityView="Raw" />
                        <TextBlock Text="NYSE Open" FontSize="11" FontWeight="Medium"
                                   Foreground="{StaticResource MeridianTextMutedBrush}" />
                    </StackPanel>
                    <Border Width="1" Height="14"
                            Background="{StaticResource MeridianBorderBrush}" />
                    <TextBlock x:Name="ClockText"
                               FontFamily="{StaticResource IBMPlexMonoFont}"
                               FontSize="12"
                               Foreground="{StaticResource MeridianTextMutedBrush}" />
                </StackPanel>
            </Grid>

            <!-- ═══════════ ROW 1: BRAILLE TICKER TAPE ═══════════ -->
            <Border Grid.Row="1" Margin="0,14,0,16"
                    Padding="0,8"
                    Height="33"
                    BorderThickness="0,1"
                    BorderBrush="{StaticResource MeridianBorderBrush}">
                <Grid x:Name="TickerTapeContainer">
                    <!-- Clipping ScrollViewer prevents text from overflowing -->
                    <ScrollViewer HorizontalScrollBarVisibility="Hidden"
                                  VerticalScrollBarVisibility="Disabled"
                                  HorizontalScrollMode="Disabled"
                                  VerticalScrollMode="Disabled"
                                  IsTabStop="False">
                        <TextBlock x:Name="TickerTapeText"
                                   AutomationProperties.AccessibilityView="Raw"
                                   FontFamily="{StaticResource IBMPlexMonoFont}"
                                   FontSize="11"
                                   Foreground="{StaticResource MeridianGainBrush}"
                                   MaxLines="1"
                                   TextTrimming="None">
                            <TextBlock.RenderTransform>
                                <TranslateTransform x:Name="TickerTranslate" />
                            </TextBlock.RenderTransform>
                        </TextBlock>
                    </ScrollViewer>
                    <!-- Fade edges: match page background color -->
                    <Border HorizontalAlignment="Left" Width="50" IsHitTestVisible="False">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                <GradientStop Color="{StaticResource MeridianBackground}" Offset="0" />
                                <GradientStop Color="{StaticResource MeridianBackgroundTransparent}" Offset="1" />
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
                    <Border HorizontalAlignment="Right" Width="50" IsHitTestVisible="False">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                <GradientStop Color="{StaticResource MeridianBackgroundTransparent}" Offset="0" />
                                <GradientStop Color="{StaticResource MeridianBackground}" Offset="1" />
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
                </Grid>
            </Border>

            <!-- ═══════════ ROW 2: PORTFOLIO HERO ═══════════ -->
            <Grid Grid.Row="2" Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Spacing="2">
                    <TextBlock Style="{StaticResource SectionLabel}"
                               Text="TOTAL PORTFOLIO VALUE"
                               CharacterSpacing="140" />
                    <TextBlock Text="$163,842.56"
                               FontFamily="{StaticResource InstrumentSerifFont}"
                               FontSize="62" FontWeight="Normal"
                               Foreground="{StaticResource MeridianTextPrimaryBrush}"
                               LineHeight="68" Margin="0,-4,0,0"
                               AutomationProperties.Name="Portfolio value: $163,842.56" />
                    <StackPanel Orientation="Horizontal" Spacing="14" Margin="0,2,0,0">
                        <Border x:Name="GainPill" CornerRadius="100"
                                Background="{StaticResource MeridianGainBgTintBrush}"
                                Padding="14,6">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <Viewbox Width="10" Height="10" VerticalAlignment="Center">
                                    <Polygon Points="5,0 10,8 0,8"
                                             Fill="{StaticResource MeridianGainBrush}" />
                                </Viewbox>
                                <TextBlock FontFamily="{StaticResource IBMPlexMonoMediumFont}"
                                           FontSize="14"
                                           Foreground="{StaticResource MeridianGainBrush}"
                                           Text="+$40,274.28" />
                                <TextBlock FontFamily="{StaticResource IBMPlexMonoMediumFont}"
                                           FontSize="13" Opacity="0.7"
                                           Foreground="{StaticResource MeridianGainBrush}"
                                           Text="(32.63%)" />
                            </StackPanel>
                        </Border>
                        <TextBlock Text="all time unrealized"
                                   FontSize="11" FontWeight="Medium"
                                   Foreground="{StaticResource MeridianTextSubtleBrush}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </StackPanel>

                <!-- Index Cards (data-bound) -->
                <ItemsRepeater Grid.Column="1" VerticalAlignment="Center"
                               ItemsSource="{Binding IndexTickers}">
                    <ItemsRepeater.Layout>
                        <StackLayout Orientation="Horizontal" Spacing="6" />
                    </ItemsRepeater.Layout>
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate>
                            <Border CornerRadius="12" BorderThickness="1"
                                    BorderBrush="{StaticResource MeridianBorderBrush}"
                                    Background="{StaticResource MeridianCardBrush}"
                                    Padding="16,8" MinWidth="120" MaxHeight="72">
                                <StackPanel Spacing="2">
                                    <TextBlock Text="{Binding Name}"
                                               FontSize="10" FontWeight="SemiBold"
                                               Foreground="{StaticResource MeridianTextSubtleBrush}"
                                               CharacterSpacing="60" />
                                    <TextBlock Text="{Binding Value}"
                                               FontFamily="{StaticResource IBMPlexMonoMediumFont}"
                                               FontSize="14" />
                                    <TextBlock Text="{Binding Change}"
                                               FontFamily="{StaticResource IBMPlexMonoMediumFont}"
                                               FontSize="11"
                                               Foreground="{Binding IsUp, Converter={StaticResource GainLossBrush}}" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>
            </Grid>

            <!-- ═══════════ ROW 3: MAIN CONTENT GRID ═══════════ -->
            <Grid Grid.Row="3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="20" />
                    <ColumnDefinition Width="360" />
                </Grid.ColumnDefinitions>

                <!-- ─── LEFT COLUMN ─── -->
                <StackPanel Grid.Column="0" Spacing="20">

                    <!-- PERFORMANCE CHART CARD -->
                    <Border CornerRadius="16" BorderThickness="1"
                            BorderBrush="{StaticResource MeridianBorderBrush}"
                            Background="{StaticResource MeridianCardBrush}"
                            Padding="28,24,28,16">
                        <StackPanel Spacing="16">
                            <!-- Chart header: dynamic for portfolio vs stock detail -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <!-- Back button (visible in stock detail mode) -->
                                    <Button x:Name="BackButton" Visibility="Collapsed"
                                            Click="OnBackButtonClick"
                                            Width="28" Height="28" Padding="0"
                                            CornerRadius="8" BorderThickness="1"
                                            BorderBrush="{StaticResource MeridianBorderBrush}"
                                            Background="Transparent"
                                            VerticalAlignment="Center">
                                        <FontIcon Glyph="&#xE72B;" FontSize="12" />
                                    </Button>

                                    <StackPanel>
                                        <TextBlock x:Name="ChartLabel"
                                                   Style="{StaticResource SectionLabel}"
                                                   Text="PERFORMANCE" />
                                        <!-- Stock detail row (visible in stock detail mode) -->
                                        <StackPanel x:Name="StockDetailPanel" Visibility="Collapsed"
                                                    Orientation="Horizontal" Spacing="8" Margin="0,3,0,0">
                                            <TextBlock x:Name="StockPrice"
                                                       FontFamily="{StaticResource IBMPlexMonoMediumFont}"
                                                       FontSize="18" />
                                            <TextBlock x:Name="StockDelta"
                                                       FontFamily="{StaticResource IBMPlexMonoMediumFont}"
                                                       FontSize="12" VerticalAlignment="Center" />
                                            <Button Content="TRADE" FontSize="10" FontWeight="Bold"
                                                    Padding="12,3" CornerRadius="8" BorderThickness="1"
                                                    BorderBrush="{StaticResource MeridianAccentBrush}"
                                                    Foreground="{StaticResource MeridianAccentBrush}"
                                                    Background="{StaticResource MeridianAccentBgTintBrush}"
                                                    Click="OnChartTradeButtonClick" />
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>

                                <!-- Timeframe selector -->
                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="2">
                                    <Button Content="1D" FontSize="10" Padding="8,4" CornerRadius="6"
                                            Background="Transparent" Foreground="{StaticResource MeridianTextSubtleBrush}" />
                                    <Button Content="1W" FontSize="10" Padding="8,4" CornerRadius="6"
                                            Background="Transparent" Foreground="{StaticResource MeridianTextSubtleBrush}" />
                                    <Button Content="1M" FontSize="10" Padding="8,4" CornerRadius="6"
                                            Background="Transparent" Foreground="{StaticResource MeridianTextSubtleBrush}" />
                                    <Button Content="3M" FontSize="10" Padding="8,4" CornerRadius="6"
                                            Background="{StaticResource MeridianGainBgTintBrush}"
                                            Foreground="{StaticResource MeridianGainBrush}" />
                                    <Button Content="YTD" FontSize="10" Padding="8,4" CornerRadius="6"
                                            Background="Transparent" Foreground="{StaticResource MeridianTextSubtleBrush}" />
                                    <Button Content="1Y" FontSize="10" Padding="8,4" CornerRadius="6"
                                            Background="Transparent" Foreground="{StaticResource MeridianTextSubtleBrush}" />
                                </StackPanel>
                            </Grid>

                            <!-- LiveCharts2 area chart -->
                            <lvc:CartesianChart x:Name="PerformanceChart"
                                                Height="240"
                                                TooltipPosition="Top"
                                                ZoomMode="None"
                                                AutomationProperties.Name="Portfolio performance chart, 3 month view" />
                        </StackPanel>
                    </Border>

                    <!-- HOLDINGS + ALLOCATION ROW -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="20" />
                            <ColumnDefinition Width="1.2*" />
                        </Grid.ColumnDefinitions>

                        <!-- ══ HOLDINGS CARD ══ -->
                        <Border Grid.Column="0" CornerRadius="16" BorderThickness="1"
                                BorderBrush="{StaticResource MeridianBorderBrush}"
                                Background="{StaticResource MeridianCardBrush}"
                                Padding="24,22">
                            <StackPanel Spacing="12">
                                <TextBlock Style="{StaticResource SectionLabel}" Text="HOLDINGS" />
                                <ItemsRepeater ItemsSource="{Binding Holdings}">
                                    <ItemsRepeater.Layout>
                                        <StackLayout Spacing="6" />
                                    </ItemsRepeater.Layout>
                                    <ItemsRepeater.ItemTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="12" BorderThickness="1"
                                                    BorderBrush="{StaticResource MeridianBorderBrush}"
                                                    Padding="12,14"
                                                    Tapped="OnHoldingTapped"
                                                    PointerEntered="OnCardPointerEntered"
                                                    PointerExited="OnCardPointerExited"
                                                    AutomationProperties.Name="{Binding Ticker}">
                                                <StackPanel Spacing="6">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="Auto" />
                                                        </Grid.RowDefinitions>

                                                        <!-- Row 0: Ticker + shares×avg + market value -->
                                                        <TextBlock Grid.Row="0" Grid.Column="0"
                                                                   FontFamily="{StaticResource OutfitFont}"
                                                                   FontSize="14" FontWeight="Bold">
                                                            <Run Text="{Binding Ticker}" />
                                                            <Run Text="  " />
                                                            <Run Text="{Binding Shares}" FontSize="10"
                                                                 Foreground="{StaticResource MeridianTextSubtleBrush}" />
                                                            <Run Text=" × $" FontSize="10"
                                                                 Foreground="{StaticResource MeridianTextSubtleBrush}" />
                                                            <Run Text="{Binding AvgCost}" FontSize="10"
                                                                 Foreground="{StaticResource MeridianTextSubtleBrush}" />
                                                        </TextBlock>

                                                        <TextBlock Grid.Row="0" Grid.Column="1"
                                                                   FontFamily="{StaticResource IBMPlexMonoFont}"
                                                                   FontSize="13" HorizontalAlignment="Right"
                                                                   Text="{Binding MarketValue, Converter={StaticResource DecimalFormat}, ConverterParameter='$#,##0.00'}" />

                                                        <!-- Row 1: Gain % -->
                                                        <TextBlock Grid.Row="1" Grid.Column="1"
                                                                   FontFamily="{StaticResource IBMPlexMonoFont}"
                                                                   FontSize="11" HorizontalAlignment="Right"
                                                                   Foreground="{Binding IsPositive, Converter={StaticResource GainLossBrush}}"
                                                                   Margin="0,2,0,0"
                                                                   Text="{Binding GainPct, Converter={StaticResource DecimalFormat}, ConverterParameter='+0.00;-0.00;0.00'}" />
                                                    </Grid>

                                                    <!-- Weight bar: 3px height, green, width proportional to portfolio weight -->
                                                    <Border Height="3" CornerRadius="2"
                                                            Background="{StaticResource MeridianBorderBrush}"
                                                            HorizontalAlignment="Stretch">
                                                        <Border Height="3" CornerRadius="2"
                                                                Background="{StaticResource MeridianGainBrush}"
                                                                HorizontalAlignment="Left"
                                                                Width="80" />
                                                    </Border>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsRepeater.ItemTemplate>
                                </ItemsRepeater>
                            </StackPanel>
                        </Border>

                        <!-- Allocation + Volume Stack -->
                        <StackPanel Grid.Column="2" Spacing="20">
                            <Border CornerRadius="16" BorderThickness="1"
                                    BorderBrush="{StaticResource MeridianBorderBrush}"
                                    Background="{StaticResource MeridianCardBrush}"
                                    Padding="24,22">
                                <StackPanel Spacing="14">
                                    <TextBlock Style="{StaticResource SectionLabel}"
                                               Text="SECTOR ALLOCATION" />
                                    <controls:SectorRingControl
                                        x:Name="SectorRing"
                                        Sectors="{Binding Sectors}" />
                                </StackPanel>
                            </Border>
                            <Border CornerRadius="16" BorderThickness="1"
                                    BorderBrush="{StaticResource MeridianBorderBrush}"
                                    Background="{StaticResource MeridianCardBrush}"
                                    Padding="24,22">
                                <StackPanel Spacing="8">
                                    <TextBlock Style="{StaticResource SectionLabel}"
                                               Text="VOLUME PROFILE" />
                                    <controls:VolumeChartControl
                                        x:Name="VolumeChart"
                                        VolumeData="{Binding Volume}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>
                </StackPanel>

                <!-- ─── RIGHT SIDEBAR ─── -->
                <StackPanel Grid.Column="2" Spacing="20">

                    <!-- Search Bar -->
                    <TextBox PlaceholderText="Search ticker or name…"
                             Text="{Binding SearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             FontFamily="{StaticResource OutfitFont}"
                             FontSize="13" CornerRadius="12" Padding="12,6"
                             Background="{StaticResource MeridianCardBrush}"
                             BorderThickness="1"
                             BorderBrush="{StaticResource MeridianBorderBrush}"
                             Height="36" />

                    <!-- ══ WATCHLIST CARD ══ -->
                    <Border CornerRadius="16" BorderThickness="1"
                            BorderBrush="{StaticResource MeridianBorderBrush}"
                            Background="{StaticResource MeridianCardBrush}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionLabel}"
                                       Text="WATCHLIST" Margin="22,20,22,12" />
                            <ScrollViewer MaxHeight="440" VerticalScrollBarVisibility="Auto">
                            <ItemsRepeater ItemsSource="{Binding Watchlist}"
                                           Margin="0,0,0,8">
                                <ItemsRepeater.Layout>
                                    <StackLayout Spacing="0" />
                                </ItemsRepeater.Layout>
                                <ItemsRepeater.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel>
                                            <!-- Collapsed row -->
                                            <Border Padding="14,12,22,12"
                                                    BorderThickness="0,0,0,1"
                                                    BorderBrush="{StaticResource MeridianRowSeparatorBrush}"
                                                    Tapped="OnWatchlistRowTapped"
                                                    PointerEntered="OnRowPointerEntered"
                                                    PointerExited="OnRowPointerExited">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>

                                                    <!-- Left: Ticker + braille + chevron -->
                                                    <StackPanel Grid.Column="0" Margin="8,0,0,0">
                                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                                            <TextBlock Text="{Binding Ticker}"
                                                                       FontSize="14" FontWeight="Bold"
                                                                       FontFamily="{StaticResource OutfitFont}" />
                                                            <TextBlock Tag="BrailleActivity" Text="⣤⣶⣷⣿⣶⣤" FontSize="9"
                                                                       Foreground="{Binding Pct, Converter={StaticResource GainLossBrush}}"
                                                                       Opacity="0.5"
                                                                       VerticalAlignment="Center" />
                                                            <TextBlock Text="▾" FontSize="8"
                                                                       Foreground="{StaticResource MeridianTextSubtleBrush}"
                                                                       VerticalAlignment="Center" />
                                                        </StackPanel>
                                                        <TextBlock Text="{Binding Name}" FontSize="11"
                                                                   Foreground="{StaticResource MeridianTextSubtleBrush}"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   Margin="0,1,0,0" />
                                                    </StackPanel>

                                                    <!-- Center: Sparkline mini chart -->
                                                    <controls:SparklineControl Grid.Column="1"
                                                        HorizontalAlignment="Center" VerticalAlignment="Center"
                                                        IsPositive="{Binding Pct, Converter={StaticResource IsPositive}}" />

                                                    <!-- Right: Price + Delta -->
                                                    <StackPanel Grid.Column="2" HorizontalAlignment="Right"
                                                                VerticalAlignment="Center">
                                                        <TextBlock FontFamily="{StaticResource IBMPlexMonoFont}"
                                                                   FontSize="13" HorizontalAlignment="Right">
                                                            <Run Text="$" /><Run Text="{Binding Price}" />
                                                        </TextBlock>
                                                        <TextBlock FontFamily="{StaticResource IBMPlexMonoFont}"
                                                                   FontSize="11" HorizontalAlignment="Right"
                                                                   Foreground="{Binding Pct, Converter={StaticResource GainLossBrush}}">
                                                            <Run Text="{Binding Pct}" /><Run Text="%" />
                                                        </TextBlock>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>

                                            <!-- Expanded panel (hidden by default) -->
                                            <Border Tag="ExpandedPanel" Visibility="Collapsed"
                                                    Background="{StaticResource MeridianExpandedBgBrush}"
                                                    Padding="22,14">
                                                <StackPanel Spacing="12">
                                                    <!-- OHLC Grid -->
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="Auto" />
                                                        </Grid.RowDefinitions>
                                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="OPEN"
                                                                   FontSize="9" Foreground="{StaticResource MeridianTextSubtleBrush}" />
                                                        <TextBlock Grid.Row="0" Grid.Column="1" Text="HIGH"
                                                                   FontSize="9" Foreground="{StaticResource MeridianTextSubtleBrush}" />
                                                        <TextBlock Grid.Row="0" Grid.Column="2" Text="LOW"
                                                                   FontSize="9" Foreground="{StaticResource MeridianTextSubtleBrush}" />
                                                        <TextBlock Grid.Row="0" Grid.Column="3" Text="VOLUME"
                                                                   FontSize="9" Foreground="{StaticResource MeridianTextSubtleBrush}" />
                                                        <TextBlock Grid.Row="1" Grid.Column="0"
                                                                   FontFamily="{StaticResource IBMPlexMonoFont}" FontSize="13"
                                                                   Text="{Binding Open, Converter={StaticResource DecimalFormat}, ConverterParameter='$#,##0.00'}" />
                                                        <TextBlock Grid.Row="1" Grid.Column="1"
                                                                   FontFamily="{StaticResource IBMPlexMonoFont}" FontSize="13"
                                                                   Text="{Binding High, Converter={StaticResource DecimalFormat}, ConverterParameter='$#,##0.00'}" />
                                                        <TextBlock Grid.Row="1" Grid.Column="2"
                                                                   FontFamily="{StaticResource IBMPlexMonoFont}" FontSize="13"
                                                                   Text="{Binding Low, Converter={StaticResource DecimalFormat}, ConverterParameter='$#,##0.00'}" />
                                                        <TextBlock Grid.Row="1" Grid.Column="3"
                                                                   FontFamily="{StaticResource IBMPlexMonoFont}" FontSize="13"
                                                                   Text="{Binding Volume}" />
                                                    </Grid>

                                                    <!-- Day Range Bar -->
                                                    <StackPanel Spacing="4">
                                                        <Grid>
                                                            <TextBlock Text="Day Range" FontSize="9"
                                                                       Foreground="{StaticResource MeridianTextSubtleBrush}" />
                                                            <TextBlock HorizontalAlignment="Right" FontSize="9"
                                                                       FontFamily="{StaticResource IBMPlexMonoFont}"
                                                                       Foreground="{StaticResource MeridianTextSubtleBrush}">
                                                                <Run Text="$" /><Run Text="{Binding Low}" /><Run Text=" — $" /><Run Text="{Binding High}" />
                                                            </TextBlock>
                                                        </Grid>
                                                        <Border Height="4" CornerRadius="2"
                                                                Background="{StaticResource MeridianBorderBrush}" />
                                                    </StackPanel>

                                                    <!-- Action buttons -->
                                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                                        <Button Content="View Chart" FontSize="11" Padding="14,6"
                                                                CornerRadius="8" BorderThickness="1"
                                                                BorderBrush="{StaticResource MeridianBorderBrush}"
                                                                Background="Transparent"
                                                                Tapped="OnViewChartFromWatchlist" />
                                                        <Button Content="Trade" FontSize="11" Padding="14,6"
                                                                CornerRadius="8" BorderThickness="1"
                                                                BorderBrush="{StaticResource MeridianAccentBrush}"
                                                                Foreground="{StaticResource MeridianAccentBrush}"
                                                                Background="{StaticResource MeridianAccentBgTintBrush}"
                                                                Tapped="OnWatchlistTradeButtonTapped" />
                                                    </StackPanel>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsRepeater.ItemTemplate>
                            </ItemsRepeater>
                            </ScrollViewer>
                        </StackPanel>
                    </Border>

                    <!-- ══ MARKET PULSE (NEWS) CARD ══ -->
                    <Border CornerRadius="16" BorderThickness="1"
                            BorderBrush="{StaticResource MeridianBorderBrush}"
                            Background="{StaticResource MeridianCardBrush}"
                            Padding="22,20,22,16">
                        <StackPanel Spacing="14">
                            <Grid>
                                <TextBlock Style="{StaticResource SectionLabel}"
                                           Text="MARKET PULSE" />
                                <TextBlock x:Name="BraillePulse"
                                           HorizontalAlignment="Right"
                                           FontSize="11" Opacity="0.5"
                                           Foreground="{StaticResource MeridianAccentBrush}"
                                           Text="⣤⣴⣶⣷⣿⣷⣶⣴⣤⠀⠀⠀⠀⠀⠀⠀⠀⠀"
                                           AutomationProperties.AccessibilityView="Raw" />
                            </Grid>
                            <ItemsRepeater ItemsSource="{Binding News}">
                                <ItemsRepeater.Layout>
                                    <StackLayout Spacing="14" />
                                </ItemsRepeater.Layout>
                                <ItemsRepeater.ItemTemplate>
                                    <DataTemplate>
                                        <Grid PointerEntered="OnNewsItemPointerEntered"
                                              PointerExited="OnNewsItemPointerExited">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>

                                            <!-- Tag badge -->
                                            <Border Grid.Column="0" CornerRadius="6"
                                                    Padding="8,3" Margin="0,0,12,0"
                                                    VerticalAlignment="Top"
                                                    Background="{Binding Tag, Converter={StaticResource TagToBrush}}">
                                                <TextBlock Text="{Binding Tag}"
                                                           FontSize="9" FontWeight="SemiBold"
                                                           CharacterSpacing="40" />
                                            </Border>

                                            <!-- Headline + timestamp -->
                                            <StackPanel Grid.Column="1" Spacing="3">
                                                <TextBlock Text="{Binding Text}"
                                                           FontSize="12" TextWrapping="Wrap"
                                                           LineHeight="17" />
                                                <TextBlock FontFamily="{StaticResource IBMPlexMonoFont}"
                                                           FontSize="10"
                                                           Foreground="{StaticResource MeridianTextSubtleBrush}">
                                                    <Run Text="{Binding Time}" /><Run Text=" ago" />
                                                </TextBlock>
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsRepeater.ItemTemplate>
                            </ItemsRepeater>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>

            <!-- ═══════════ ROW 4: FOOTER ═══════════ -->
            <Grid Grid.Row="4" Margin="0,24,0,0"
                  Padding="0,16,0,0"
                  BorderThickness="0,1,0,0"
                  BorderBrush="{StaticResource MeridianBorderBrush}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" FontSize="10"
                           Foreground="{StaticResource MeridianTextSubtleBrush}"
                           Text="Simulated data for demonstration. Not financial advice." />
                <TextBlock Grid.Column="1"
                           Text="⣤⣴⣶⣷⣿⣶⣴⣤ AAPL ⣤⣴⣶"
                           FontFamily="{StaticResource IBMPlexMonoFont}"
                           FontSize="9" Opacity="0.4"
                           HorizontalAlignment="Center"
                           Foreground="{StaticResource MeridianTextSubtleBrush}"
                           MaxWidth="300" />
                <TextBlock Grid.Column="2"
                           FontFamily="{StaticResource IBMPlexMonoFont}"
                           FontSize="10"
                           Foreground="{StaticResource MeridianTextSubtleBrush}"
                           Text="Meridian Terminal v4.0" />
            </Grid>
        </Grid>
    </ScrollViewer>

    <!-- ═══════════ TRADE DRAWER OVERLAY ═══════════ -->
    <!-- Backdrop -->
    <Border x:Name="DrawerBackdrop" Visibility="Collapsed"
            Background="{StaticResource MeridianBackdropBrush}"
            Tapped="OnDrawerBackdropTapped" />

    <!-- Drawer (right-aligned) -->
    <views:TradeDrawer x:Name="TradeDrawerPanel" Visibility="Collapsed"
                       HorizontalAlignment="Right" VerticalAlignment="Stretch" />
    </Grid>
</Page>
